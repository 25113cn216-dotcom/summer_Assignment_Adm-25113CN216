    //Count digits in a number//
    #include <stdio.h>

    int main() {
    int num, count = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    if (num == 0) {
        count = 1;
    } else {
        if (num < 0) {
            num = -num;
        }

        while (num > 0) {
            count++;
            num = num / 10;
        }
    }

    printf("Number of digits = %d\n", count);

    return 0;
}
